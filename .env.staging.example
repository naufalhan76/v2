# MSN ERP V2 — Staging environment
# V2 uses a separate Supabase project (different from V1).
# Copy this file to .env.staging and fill in real values from the V2
# Supabase dashboard (Settings → API) and the secure store for secrets.

# ============================================================
# Supabase (V2 project — different from V1)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://dejzpeytapjolajveond.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Web Push (VAPID) — Phase 4
# Generate via: npm run vapid:gen (or use V1's keys if already deployed)
# ============================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nufnh.my.id

# ============================================================
# Optional services
# ============================================================
RESEND_API_KEY=

# ============================================================
# Cron — daily reminder generation
# Long random string (e.g. `openssl rand -hex 32`). Used by
# POST /api/admin/reminders/run to authorize unattended cron
# calls. Leave blank to require an authenticated session.
# See docs/CRON-SETUP.md.
# ============================================================
CRON_SECRET=

# ============================================================
# Bootstrap test accounts — read by scripts/bootstrap-staging.mjs
# Generate passwords with: openssl rand -base64 24
# These are REAL accounts on the staging Supabase project; keep
# them out of source control (only commit this .example template).
# ============================================================
STAGING_SUPERADMIN_EMAIL=superadmin@example.test
STAGING_SUPERADMIN_PASSWORD=
STAGING_ADMIN_EMAIL=admin@example.test
STAGING_ADMIN_PASSWORD=
STAGING_FINANCE_EMAIL=finance@example.test
STAGING_FINANCE_PASSWORD=
STAGING_TEKNISI1_EMAIL=teknisi1@example.test
STAGING_TEKNISI1_PASSWORD=
STAGING_TEKNISI2_EMAIL=teknisi2@example.test
STAGING_TEKNISI2_PASSWORD=
